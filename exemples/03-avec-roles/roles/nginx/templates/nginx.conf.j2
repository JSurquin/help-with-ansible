# Nginx configuration generated by Ansible
# Role: nginx
# Generated on: {{ ansible_facts['date_time']['iso8601'] }}

# User under which Nginx runs
user {{ nginx_user }};
# Number of worker processes
worker_processes {{ nginx_worker_processes }};
# PID file for process management
pid /run/nginx.pid;
# Include enabled modules
include /etc/nginx/modules-enabled/*.conf;

# Events configuration block
events {
    # Concurrent connections per worker
    worker_connections {{ nginx_worker_connections }};
    # Option: accept multiple connections at once (commented out)
    # multi_accept on;
}

# HTTP configuration block
http {
    ##
    # Basic Settings
    ##
    # Optimization: use sendfile() for file delivery
    sendfile on;
    # Optimization: send headers and start of file together
    tcp_nopush on;
    # Optimization: disable Nagle's algorithm
    tcp_nodelay on;
    # Keep-alive timeout
    keepalive_timeout {{ nginx_keepalive_timeout }};
    # Maximum MIME types hash table size
    types_hash_max_size 2048;
    # Maximum request size (uploads)
    client_max_body_size {{ nginx_client_max_body_size }};

    # Hide Nginx version (commented out)
    # server_tokens off;
    # Bucket size for server names (commented out)
    # server_names_hash_bucket_size 64;
    # Do not use server_name in redirects (commented out)
    # server_name_in_redirect off;

    # Include standard MIME types
    include /etc/nginx/mime.types;
    # Default MIME type for unknown files
    default_type application/octet-stream;

    ##
    # SSL Settings
    ##
    # Allowed SSL/TLS protocols (secure only)
    ssl_protocols TLSv1.2 TLSv1.3;
    # Prefer server cipher order
    ssl_prefer_server_ciphers on;

    ##
    # Logging Settings
    ##
    # HTTP access log file
    access_log {{ nginx_log_path }}/access.log;
    # Error log file
    error_log {{ nginx_log_path }}/error.log;

    ##
    # Gzip Settings
    ##
    # Enable or disable gzip based on variable
    gzip {{ 'on' if nginx_gzip_enabled else 'off' }};
{% if nginx_gzip_enabled %}
    # Add Vary: Accept-Encoding header
    gzip_vary on;
    # Also compress proxied responses
    gzip_proxied any;
    # Compression level (1-9, 6 = good balance)
    gzip_comp_level 6;
    # MIME types to compress
    gzip_types text/plain text/css text/xml text/javascript 
               application/json application/javascript application/xml+rss 
               application/rss+xml font/truetype font/opentype 
               application/vnd.ms-fontobject image/svg+xml;
{% endif %}

    ##
    # Virtual Host Configs
    ##
    # Include all enabled vhosts
    include {{ nginx_vhost_enabled_path }}/*;
}
