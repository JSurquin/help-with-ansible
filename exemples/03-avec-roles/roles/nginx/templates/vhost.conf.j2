# Virtual host for {{ item.server_name }}
# Generated by Ansible on {{ ansible_facts['date_time']['date'] }}

# Virtual host configuration block
server {
    # IPv4 listen port
    listen {{ item.port | default(nginx_listen_port) }};
{% if nginx_listen_ipv6 %}
    # IPv6 listen port
    listen [::]:{{ item.port | default(nginx_listen_port) }};
{% endif %}

    # Vhost domain name
    server_name {{ item.server_name }};
    
    # Site root directory
    root {{ item.root }};
    # Index files in priority order
    index index.html index.htm index.nginx-debian.html;

    # Vhost-specific logs
    access_log {{ nginx_log_path }}/{{ item.server_name }}-access.log;
    error_log {{ nginx_log_path }}/{{ item.server_name }}-error.log;

    # Main configuration - site root
    location / {
        # Try file, then directory, otherwise 404
        try_files $uri $uri/ =404;
    }

    # Health check endpoint
    location /health {
        # Do not log these requests
        access_log off;
        # Return 200 with "OK" message
        return 200 "OK\n";
        # Set response MIME type
        add_header Content-Type text/plain;
    }

    # Status endpoint - Nginx statistics (optional)
    location /status {
        # Enable stub_status module
        stub_status on;
        # Do not log these requests
        access_log off;
        # Allow localhost only
        allow 127.0.0.1;
        # Deny all other access
        deny all;
    }

{% if item.extra_config is defined %}
    # Additional configuration
    {{ item.extra_config | indent(4) }}
{% endif %}
}
