# Nginx configuration generated by Ansible
# Server: {{ inventory_hostname }}
# Date: {{ ansible_facts['date_time']['date'] }} {{ ansible_facts['date_time']['time'] }}

# User under which Nginx runs
user www-data;
# Number of workers (auto by default)
worker_processes {{ nginx_worker_processes | default('auto') }};
# File containing the main process PID
pid /run/nginx.pid;

# Events configuration block
events {
    # Concurrent connections per worker
    worker_connections {{ nginx_config.worker_connections }};
}

# Main HTTP configuration block
http {
    # Basic settings
    # Optimization: use sendfile() for file delivery
    sendfile on;
    # Optimization: send headers and file together
    tcp_nopush on;
    # Optimization: disable Nagle's algorithm
    tcp_nodelay on;
    # Keep-alive timeout in seconds
    keepalive_timeout 65;
    # Maximum MIME types hash table size
    types_hash_max_size 2048;
    # Maximum request size (uploads)
    client_max_body_size {{ nginx_config.client_max_body_size }};

    # MIME types - include the standard MIME type list
    include /etc/nginx/mime.types;
    # Default type for unknown files
    default_type application/octet-stream;

    # Logs
    # HTTP access log
    access_log /var/log/nginx/access.log;
    # Error log
    error_log /var/log/nginx/error.log;

    # Gzip compression
    # Enable gzip compression
    gzip on;
    # Disable for Internet Explorer 6 (known bug)
    gzip_disable "msie6";

    # Virtual host configuration
    server {
        # HTTP listen port
        listen {{ nginx_config.port }};
        # Server domain name
        server_name {{ inventory_hostname }};

        # Site root directory
        root /var/www/html;
        # Default index file
        index index.html;

        # Root location configuration
        location / {
            # Try file, then directory, otherwise 404
            try_files $uri $uri/ =404;
        }

        # Health check endpoint
        location /health {
            # Do not log these requests
            access_log off;
            # Return 200 with "OK" message
            return 200 "OK";
            # Content type: plain text
            add_header Content-Type text/plain;
        }
    }
}
